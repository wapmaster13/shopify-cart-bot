{% schema %}
{
  "name": "Cart Bot Monitor",
  "target": "body",
  "settings": []
}
{% endschema %}

<script>
(function() {
  var shop = "{{ shop.permanent_domain }}";
  var v = "{{ shop.metafields.cartbot.last_updated.value | default: '1' }}";
  var serverUrl = 'https://cartbot-shopify.fly.dev'; // Production Fly.io URL
  var cartbotUrl = "{{ 'cartbot.js' | asset_url }}";

  function loadScript(url, callback) {
    var script = document.createElement("script");
    script.type = "text/javascript";
    script.src = url;
    script.defer = true;
    if (callback) script.onload = callback;
    script.onerror = function() { console.error("CartBot: Failed to load " + url); };
    document.head.appendChild(script);
  }

  // Simple direct loads
  loadScript(serverUrl + '/public/rules/' + shop + '?v=' + v, function() {
    loadScript(cartbotUrl);
  });
})();
</script>