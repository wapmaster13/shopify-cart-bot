{% schema %}
{
  "name": "Cart Bot Monitor",
  "target": "body",
  "settings": []
}
{% endschema %}

<style>
  .shopify-payment-button,
  [data-shopify="payment-button"] {
    display: none !important;
  }
</style>

<script>
(function() {
  var shop = "{{ shop.permanent_domain }}";
  var v = "{{ shop.metafields.cartbot.last_updated.value | default: '1' }}";
  var serverUrl = 'https://nonidiomatic-verda-direly.ngrok-free.dev'; // Stable Ngrok URL

  function loadScript(url, callback) {
    var script = document.createElement("script");
    script.type = "text/javascript";
    script.src = url;
    script.defer = true;
    if (callback) script.onload = callback;
    script.onerror = function() { console.error("CartBot: Failed to load " + url); };
    document.head.appendChild(script);
  }

  // Simple direct loads
  loadScript(serverUrl + '/public/rules/' + shop + '?v=' + v, function() {
    loadScript(serverUrl + '/public/cart-bot/js?shop=' + shop + '&v=' + v);
  });
})();
</script>